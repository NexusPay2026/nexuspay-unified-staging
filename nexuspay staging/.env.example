# ═══════════════════════════════════════════════════════════════
#  NexusPay Intelligence — Environment Variables
#  Copy to .env for local dev. In production, set these in Render Dashboard.
# ═══════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────
APP_ENV=development

# ── Database (REQUIRED — no SQLite fallback) ─────────────────
DATABASE_URL=postgresql://nexuspay:password@localhost:5432/nexuspay

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRE_HOURS=72

# ── AI Provider Keys (set the ones you have) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
GROK_API_KEY=xai-...

# ── Cloudflare R2 Object Storage ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexuspay-storage
R2_PUBLIC_URL=

# ── Frontend URLs ────────────────────────────────────────────
WEBSITE_URL=https://nexuspayservices.com
LANDING_PAGE_URL=https://freeanalysis.nexuspayservices.com
PORTAL_URL=https://nexuspayai.com
DASHBOARD_URL=https://nexuspaydashboard.netlify.app
API_BASE_URL=https://nexuspay-api-ochi.onrender.com

# ── Microsoft Bookings ──────────────────────────────────────
MICROSOFT_BOOKINGS_URL=

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@nexuspayservices.com

# ── Webhook (optional shared secret for landing page POST) ───
WEBHOOK_SECRET=
